# Firebase configuration for production
# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console -> Project Settings -> Your Apps -> Web App Config
#
# For local development with the Firebase Emulator (the default when running npm run dev),
# these values are not required — the app uses demo-* fallbacks automatically.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
