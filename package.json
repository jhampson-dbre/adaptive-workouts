{
  "name": "adaptive-workouts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "ci:test": "vitest run",
    "ci:lint": "oxlint --deny-warnings",
    "ci:build": "vite build && node scripts/check-bundle-budget.mjs",
    "ci:rules": "node scripts/ci-rules.mjs",
    "ci:workflow": "node --test scripts/validate-review-lifecycle.node.mjs scripts/validate-agent-workflow.node.mjs && node scripts/validate-agent-workflow.mjs",
    "ci:agent-models": "node --test scripts/validate-agent-models.mjs",
    "ci:check": "npm run ci:test && npm run ci:lint && npm run ci:build && npm run ci:rules && npm run ci:workflow && npm run ci:agent-models",
    "preview": "vite preview",
    "test": "vitest",
    "approve-user": "node scripts/manage-user-approval.mjs approve",
    "revoke-user": "node scripts/manage-user-approval.mjs revoke",
    "emulators": "node scripts/emulator/run-emulators.mjs",
    "emulators:scratch": "node scripts/emulator/run-emulators.mjs --scratch",
    "emulators:scenario": "node scripts/emulator/scenarios/load.mjs",
    "test:emulator-baseline": "node scripts/emulator/run-integration-tests.mjs",
    "dev:baseline": "node scripts/emulator/run-baseline-dev.mjs",
    "verify:baseline-production": "node scripts/emulator/verify-baseline-production.mjs",
    "ux:private-access": "node scripts/emulator/access-scenarios/run.mjs"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "firebase-admin": "^14.2.0",
    "firebase-tools": "^15.22.4",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
